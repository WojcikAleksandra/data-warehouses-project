  <Source dwd:design-time-name="7bd01429-8569-4c65-888d-05a0998738d5">
    <DataSourceViewID>Power Outages Dwh</DataSourceViewID>
  </Source>
  <MdxScripts>
    <MdxScript dwd:design-time-name="8e9e5199-86f9-40a0-9bba-530b10777cd3">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;     
CREATE MEMBER CURRENTCUBE.[Measures].injuries_total
 AS [Measures].[Injuries Direct] + [Measures].[Injuries Indirect], 
FORMAT_STRING = "Standard", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Event';     
CREATE MEMBER CURRENTCUBE.[Measures].deaths_total
 AS [Measures].[Deaths Direct] + [Measures].[Deaths Indirect], 
FORMAT_STRING = "Standard", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Event';     
CREATE MEMBER CURRENTCUBE.[Measures].damage_total
 AS [Measures].[Damage Crops] + [Measures].[Damage Property], 
FORMAT_STRING = "Standard", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Event';     
CREATE MEMBER CURRENTCUBE.[Measures].percent_customers_out
 AS IIF(
    IsEmpty([Measures].[Customers Out]) 
    OR IsEmpty([Measures].[Maximum Population]) 
    OR [Measures].[Maximum Population] = 0,
    NULL,
    100.0 * [Measures].[Customers Out] / [Measures].[Maximum Population]
), 
FORMAT_STRING = "Standard", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Power Outages'  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>