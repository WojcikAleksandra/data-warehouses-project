          SQLTask:SqlStatementSource="UPDATE T&#xA;SET&#xA;    T.STATE = S.STATE,&#xA;    T.STATE_FIPS = S.STATE_FIPS,&#xA;    T.BEGIN_DATE = S.BEGIN_DATE,&#xA;    T.END_DATE = S.END_DATE,&#xA;    T.BEGIN_TIME = S.BEGIN_TIME,&#xA;    T.END_TIME = S.END_TIME,&#xA;    T.CZ_FIPS = S.CZ_FIPS,&#xA;    T.CZ_TYPE = S.CZ_TYPE,&#xA;    T.EVENT_TYPE = S.EVENT_TYPE&#xA;FROM StormEvents AS T&#xA;JOIN StormEvents_stag AS S ON T.id = S.id;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
